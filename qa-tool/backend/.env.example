# ── QA Tool — Environment Variables ─────────────────────────────────────────
# Copy to `.env` and fill in real values. Never commit `.env` to git.

# Server
PORT=5000
NODE_ENV=production

# ── Authentication secrets (REQUIRED in production) ────────────────────────
# Used to sign JWT tokens. Rotate periodically.
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_long_random_string_at_least_32_chars

# Used to encrypt per-user API keys (Claude, JIRA, webhooks) at rest.
# Generate: openssl rand -hex 32
APP_SECRET=CHANGE_ME_long_random_string_at_least_32_chars

# JWT expiry
JWT_EXPIRES_IN=7d

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Empty = allow all (dev only).
# Production example: https://qa.example.com
ALLOWED_ORIGINS=

# ── Rate limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_MAX=2000

# ── Email Monitor (existing feature) ────────────────────────────────────────
EMAIL_ADDRESS=yourname@gmail.com
EMAIL_PASSWORD=your-app-password-here
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SUBJECT_KEYWORD=deployment done
POLL_INTERVAL=120
DEFAULT_REQUIREMENTS=login register payment claims dashboard navigation search password profile logout form
