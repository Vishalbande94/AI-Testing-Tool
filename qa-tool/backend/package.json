{
  "name": "qa-tool-backend",
  "version": "1.0.0",
  "description": "QA AI Testing Tool - Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --test tests/*.test.js",
    "test:base": "node --test tests/e2e.test.js",
    "test:advanced": "node --test tests/e2e-advanced.test.js",
    "test:verbose": "node --test --test-reporter=spec tests/*.test.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "helmet": "^8.1.0",
    "imap-simple": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "mailparser": "^3.9.5",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.3",
    "pdf-parse": "^1.1.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
